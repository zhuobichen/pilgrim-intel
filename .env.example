# Pilgrim Intel Environment Variables
# Copy to .env and fill in your values

# DeepSeek API (required for AI digest generation)
DEEPSEEK_API_KEY=sk-your-key-here

# Email push (QQ邮箱)
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your-email@qq.com
EMAIL_PASSWORD=your-smtp-authorization-code
EMAIL_TO=recipient@qq.com

# Optional: other push channels (future)
# DINGTALK_WEBHOOK=
# DINGTALK_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
