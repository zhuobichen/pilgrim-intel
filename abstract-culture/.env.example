# ============ AI模型配置（必填） ============
# 方案C: DeepSeek（国内推荐，性价比最高）
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_API_BASE=https://api.deepseek.com/v1

# ============ AI模型参数 ============
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.8

# ============ 数据抓取配置 ============
CRAWLER_TIMEOUT=20
CRAWLER_MAX_CONCURRENCY=6

# ============ 推送配置（可选） ============
PUSH_TYPE=none
SERVERCHAN_KEY=your-key
BARK_KEY=your-key
TELEGRAM_BOT_TOKEN=your-token
TELEGRAM_CHAT_ID=your-chat-id
DINGTALK_WEBHOOK=your-webhook
DINGTALK_SECRET=your-secret
